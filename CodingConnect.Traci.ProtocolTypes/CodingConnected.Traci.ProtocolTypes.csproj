<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
        <Title>ProtocolTypes for Traci</Title>
        <Authors>CodingConnected, Minokori</Authors>
        <PackageOutputPath>D:\Lenovo\Documents\Visual Studio 2022\Nuget Debug Packages\</PackageOutputPath>
        <Company>CodingConnected,Minokori</Company>
        <Description>Protocol Types for Traci.</Description>
        <PackageProjectUrl>https://github.com/Minokori/CodingConnected.Traci/tree/feature_updates</PackageProjectUrl>
        <Copyright>MIT License, Copyright (c) 2017-2018 CodingConnected e.U., Menno van der Woude; MIT License, Minokori</Copyright>
        <PackageTags>Traci;SUMO</PackageTags>
        <PackageReleaseNotes>
            Break Change.
            Split the original project into 3 parts.
        </PackageReleaseNotes>
        <PackageIcon>sumo-logo.png</PackageIcon>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <AnalysisLevel>latest-all</AnalysisLevel>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
        <IsAotCompatible>True</IsAotCompatible>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
        <IsAotCompatible>True</IsAotCompatible>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\CodingConnected.Traci.Constants\CodingConnected.Traci.Constants.csproj" />
        <ProjectReference Include="..\CongdingConnected.Traci.DataTypes\CodingConnected.Traci.DataTypes.csproj" />
    </ItemGroup>
    <ItemGroup>
        <Using Include="CodingConnected.Traci.Constants" />
        <Using Include="CodingConnected.Traci.DataTypes" />
    </ItemGroup>
    <ItemGroup>
        <None Update="README.md">
            <Pack>True</Pack>
            <PackagePath>\</PackagePath>
        </None>
        <None Update="sumo-logo.png">
            <Pack>True</Pack>
            <PackagePath>\</PackagePath>
        </None>
    </ItemGroup>

</Project>
